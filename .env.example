# Canvas LMS — шаблон. Скопируйте в .env и заполните.
# Файл .env в .gitignore и не попадает в git.

CANVAS_BASE_URL=https://canvas.letovo.ru
CANVAS_API_URL=https://canvas.letovo.ru/api/v1
CANVAS_ACCESS_TOKEN=
# Опционально: id аккаунта для create-course (Letovo IT — обычно 6)
# CANVAS_ACCOUNT_ID=6
# ID курса 8 класса (ML: 8) в Canvas
# CANVAS_COURSE_ID_08=6465
