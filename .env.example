# Canvas LMS — шаблон. Скопируйте в .env и заполните.
# Файл .env в .gitignore и не попадает в git.

CANVAS_BASE_URL=https://canvas.letovo.ru
CANVAS_API_URL=https://canvas.letovo.ru/api/v1

# Personal Access Token (Account → Settings → Approved Integrations → New Access Token).
# Рекомендация: Expiration оставить пустым (или длинный срок). Короткий expires_at → HTTP 401.
# После Regenerate в Canvas обязательно замените значение здесь — старый токен сразу недействителен.
# Не коммитьте, не вставляйте в чат. Проверка: python scripts/canvas_api.py self
CANVAS_ACCESS_TOKEN=

# Опционально: id аккаунта для create-course (Letovo IT — обычно 6)
# CANVAS_ACCOUNT_ID=6
# ID курса 8 класса (ML: 8) в Canvas
# CANVAS_COURSE_ID_08=6465
